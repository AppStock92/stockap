# ============================================================
# .env.example — Copier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env dans Git !
# ============================================================

# Environnement : development | production | testing
FLASK_ENV=development

# Clé secrète — générer avec :
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string

# Base de données
# SQLite (dev) :
DATABASE_URL=sqlite:///stock.db
# PostgreSQL (prod) :
# DATABASE_URL=postgresql://user:password@localhost:5432/stockdb

# Email (Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ton_email@gmail.com
MAIL_PASSWORD=ton_mot_de_passe_application
